{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "SUSTN Dev",
    "version": "0.1.0",
    "identifier": "app.sustn.desktop.dev",
    "build": {
        "beforeDevCommand": "pnpm vite:dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "SUSTN Dev",
                "label": "main",
                "url": "/",
                "width": 1200,
                "height": 800,
                "decorations": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": ["icons/icon.icns", "icons/icon.ico", "icons/icon.png"]
    },
    "plugins": {
        "shell": {
            "open": true
        },
        "sql": {
            "preload": ["sqlite:sustn.db"]
        },
        "deep-link": {
            "desktop": {
                "schemes": ["sustn-dev"]
            }
        }
    }
}
